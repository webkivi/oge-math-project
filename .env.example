# Шаблон переменных окружения бэкенда. Секретов здесь нет (CLAUDE.md §6).
# Скопируй в .env и задай значения под свою среду.

# Среда исполнения: production | staging | test.
# production — жёсткий гейт grade=8 (D-6). Незаданное/неизвестное значение → production (fail-safe).
APP_ENV=production

# Строка подключения к БД (по умолчанию — локальный SQLite-файл).
DATABASE_URL=sqlite:///./oge_math.sqlite3

# Метаданные Политики обработки ПД (reg api E1). Текст/версия политики — зона юриста (Z-2).
PD_POLICY_VERSION=2026-06-19
PD_POLICY_URL=/policy
# false → чекбокс согласия неактивен, регистрацию нельзя завершить (RF-04).
PD_POLICY_AVAILABLE=true

# Z-1 (reg api §4.2): закрыта ли юр-зависимость согласия представителя <14.
# false (дефолт, fail-safe) → аккаунты grade=9 помечаются consent_cohort_flag (обратимость, RF-08).
Z1_CONSENT_RESOLVED=false
